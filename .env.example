# URL public cua service Render
RENDER_API_URL=https://yolo-r92p.onrender.com
# Dat giong nhau o local va Render neu muon khoa endpoint /update

# Render free hay ngu, de timeout dai hon de wake-up kip
ENABLE_CAMERA=1
UPDATE_TOKEN=mot_chuoi_bi_mat
RENDER_SYNC_TIMEOUT=20
RENDER_WAKE_TIMEOUT=70
RENDER_WAKE_AFTER=600
CAMERA_OFFLINE_AFTER_SECONDS=10
YOLO_MODEL_PATH=yolov8s.pt
INFER_IMG_SIZE=416
PROCESS_EVERY_N_FRAMES=1
FALLBACK_DETECT_INTERVAL=6
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
CAMERA_BUFFER_SIZE=1
IDLE_SLEEP_SECONDS=0.005
